# 3. INICIALIZAÇÃO DO ESTADO DA CONVERSA
if "messages" not in st.session_state:
    # Primeira mensagem do Gui usando a saudação exata parametrizada
    st.session_state.messages = [
        {"role": "assistant", "content": DATA_CONHECIMENTO["agente"]["exemplos_linguagem"]["saudacao"]}
    ]

# Renderizar mensagens anteriores do histórico
for message in st.session_state.messages:
    with st.chat_message(message["role"]):
        st.write(message["content"])

# 4. ENTRADA DE TEXTO DO USUÁRIO
